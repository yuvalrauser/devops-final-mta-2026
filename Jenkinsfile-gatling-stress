// Jenkinsfile-gatling-stress
pipeline {
    agent any
    options {
        timestamps()
        timeout(time: 12, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }
    environment {
        GATLING_HOME = 'C:\\DevOps\\gatling-charts-highcharts-bundle-3.10.4-bundle\\gatling-charts-highcharts-bundle-3.10.4'
        SIM_DIR      = 'C:\\DevOps\\FinalProject\\gatling'
    }
    stages {
        stage('Run Gatling stress (1000 RPS / 5 min)') {
            steps {
                bat """
                  @echo on
                  if exist gatling-results rmdir /S /Q gatling-results
                  mkdir gatling-results
                  "%GATLING_HOME%\\bin\\gatling.bat" ^
                    -sf "%SIM_DIR%" ^
                    -s BmiStressSimulation ^
                    -rf "%WORKSPACE%\\gatling-results" ^
                    -rd "Stress: constant 1000 RPS for 5 minutes (localhost)"
                """
            }
        }
    }
    post {
        always {
            archiveArtifacts artifacts: 'gatling-results/**', allowEmptyArchive: true
        }
    }
}
