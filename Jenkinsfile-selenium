// Jenkinsfile-selenium — runs the Selenium IDE .side file headlessly via
// selenium-side-runner. Runs on-demand only (Build Now) because it's a
// regression test, not a continuous probe.
//
// Prerequisites on the agent (one-time, run manually):
//   npm install -g selenium-side-runner edgedriver
// (Edge instead of Chrome because of ongoing Chrome/ChromeDriver version-skew.
// Microsoft Edge is built on Chromium, supports the same Selenium WebDriver
// protocol, and the npm 'edgedriver' package auto-downloads the matching
// msedgedriver for the local Edge version.)
//
// This job is triggered manually for the defense ("show me your tests run").
// It does NOT poll for SCM changes — keep noise out of the build history.

pipeline {
    agent any

    options {
        timestamps()
        timeout(time: 5, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        SIDE_FILE = 'C:\\DevOps\\FinalProject\\selenium\\bmi-tests.side'
        OUT_DIR   = 'selenium-results'
    }

    stages {

        stage('Sanity: tooling present') {
            steps {
                bat """
                  @echo on
                  where node
                  where npm
                  where selenium-side-runner || (echo selenium-side-runner missing - run: npm install -g selenium-side-runner edgedriver & exit /b 1)
                  where edgedriver        || (echo edgedriver missing - run: npm install -g edgedriver & exit /b 1)
                """
            }
        }

        stage('Run Selenium suite') {
            steps {
                bat """
                  @echo on
                  if exist "%OUT_DIR%" rmdir /S /Q "%OUT_DIR%"
                  mkdir "%OUT_DIR%"
                  selenium-side-runner -c "browserName=MicrosoftEdge" --output-directory "%OUT_DIR%" --output-format junit "%SIDE_FILE%"
                """
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'selenium-results/**', allowEmptyArchive: true
            junit testResults: 'selenium-results/**/*.xml', allowEmptyResults: true
        }
        success {
            echo "Selenium suite passed — 5 validations OK"
        }
        failure {
            echo "Selenium suite FAILED — check archived JUnit XML."
        }
    }
}
